pipeline{
    agent any

    environment{
        HOME_DIR = "Docker"
        AWS_ACCESS_KEY_ID         = credentials('Jenkins-docker-access-key')
        AWS_SECRET_ACCESS_KEY     = credentials('Jenkins-docker-secret-access-key')
        SKIP_PIPELINE             = false
    }
    stages {

        stage( 'Resolve Environments') {
            steps {
                script {
                    def envFiles = findFiles(glob: "${env.HOME_DIR}/envs/*.tfvars")

                    // Build a list of envs to deploy/destroy based on flags
                    def deployTargets  = []
                    def destroyTargets = []

                    envFiles.each { file ->
                        def content   = readFile(file.path)
                        def deployEnv = file.name.replace('.tfvars', '')

                        def forceRedeploy = content =~ /force_redeploy\s*=\s*true/
                        def forceDestroy  = content =~ /force_destroy\s*=\s*true/
                
                        if (forceDestroy) {
                            echo "${deployEnv}: force_destroy = true → queued for destroy"
                            destroyTargets << deployEnv
                        } else if (forceRedeploy) {
                            echo "${deployEnv}: force_redeploy = true → queued for deploy"
                            deployTargets << deployEnv
                        } else {
                            echo "${deployEnv}: no flags set → skipping"
                        }
                    }

                    if (deployTargets.isEmpty() && destroyTargets.isEmpty()) {
                        env.SKIP_PIPELINE = true
                    }

                    // Store as comma-separated strings for downstream stages
                    env.DEPLOY_TARGETS  = deployTargets.join(',')
                    env.DESTROY_TARGETS = destroyTargets.join(',')

                    echo "Deploy targets:  ${env.DEPLOY_TARGETS}"
                    echo "Destroy targets: ${env.DESTROY_TARGETS}"
                }
            }
        }
        stage('Terraform Destroy'){
            when {
                expression{ env.DESTROY_TARGETS?.trim() }
            }
            steps{
                script {
                    env.DESTROY_TARGETS.split(',').each{ destroyEnv ->
                    sh """
                        echo 'Destroying ${destroyEnv}'

                        # Create script to delete images in ECR
                        cd ${env.HOME_DIR}
                        terraform plan \
                        --destroy \
                        -var-file=envs/${destroyEnv}.tfvars \
                        --out=destroy.tfplan
                        
                        terraform apply destroy.tfplan 
                    """
                    }
                }
            }
        }

        stage('Terraform Init'){
            when{
                expression{ env.DEPLOY_TARGETS?.trim() }
            }
            steps{
                script {
                    env.DEPLOY_TARGETS.split(',').each { deployEnv ->
                        sh """
                            echo 'Deploying ${deployEnv}'
                            cd ${env.HOME_DIR}
                            terraform init
                            terraform workspace select ${deployEnv} || terraform workspace new ${deployEnv}
                            terraform plan -var-file=envs/${deployEnv}.tfvars --out=tfplan
                            terraform apply tfplan
                        """
                    }
                }
            }
        }
        

        /*stage('Create Docker Image') {

        }*/
    }

    post {
        always {
            script {
                if (env.SKIP_PIPELINE.toBoolean()) {
                    echo "Skipping pipeline - Nothing was modified"
                }
            }
        }
        success {
            script {
                if (!env.SKIP_PIPELINE.toBoolean()) {
                    echo "Pipeline ${env.DEPLOY_TARGETS} completed successfully"  // use DEPLOY_TARGETS, not DEPLOY_ENV
                }
            }
        }
        failure {       // use failure, not unsuccessful (that's not valid)
            echo "Pipeline failed on ${env.DEPLOY_TARGETS}"
        }
    }

}

/*
aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 718254829448.dkr.ecr.us-east-1.amazonaws.com

docker images

docker tag 158c95faac5b 718254829448.dkr.ecr.us-east-1.amazonaws.com/docker-images-repo-prod:docker-image-prod

docker push 718254829448.dkr.ecr.us-east-1.amazonaws.com/docker-images-repo-prod:docker-image-prod

MANIFEST=$(aws ecr batch-get-image --repository-name docker-images-repo-prod --image-ids imageTag=tag --output text --query 'images[].imageManifest')
aws ecr put-image --repository-name docker-images-repo-prod --image-tag 2017.03 --image-manifest "$MANIFEST"

aws ecr put-image --repository-name docker-images-repo-prod --image-tag docker-image-prod-v1 --image-manifest "$MANIFEST"

aws ecr describe-images --repository-name ecr-repo-unkown

aws ecr batch-delete-image --repository-name docker-images-repo-prod --image-ids imageTag=tag

