pipeline {
    agent any
    parameters {
        string(
            name: 'USERNAME',
            defaultValue: 'test_user_1',
            description: 'Enter your username for IAM access.'
        )
    }
    environment{
        AWS_ACCESS_KEY_ID         = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY     = credentials('AWS_SECRET_ACCESS_KEY')
        TF_VAR_project_region     = "us-east-1"
        TF_VAR_new_username       = "${params.USERNAME}"
        HOME_DIR                  = "Bootstrap"
        
    }


    stages {
        stage('Setup'){
            steps{
                sh """
                    cd ${env.HOME_DIR}
                    echo 'Setup - current directory is ${env.HOME_DIR}'
                """
            }
        }
        stage('Terraform init'){
            steps{
                sh """
                    cd ${env.HOME_DIR}
                    echo 'init - current directory is ${env.HOME_DIR}'
                    terraform init
                """
            }
        }

        stage('Terraform Plan'){
            steps{
                sh """
                    cd ${env.HOME_DIR}
                    echo 'Plan - current directory is ${env.HOME_DIR}'
                    terraform plan
                """
            }
        }

        stage('Terraform Apply'){
            steps{
                sh """
                    cd ${env.HOME_DIR}
                    echo 'Apply - current directory is ${env.HOME_DIR}'
                    terraform apply --auto-approve
                """
            }
        }
    }
}