// AUDIT TRAIL - version 5.0.0 May 15th 2025

pipeline {
    agent any
    environment{
        AWS_ACCESS_KEY_ID         = credentials('Jenkins-bootstrap-access-key')
        AWS_SECRET_ACCESS_KEY     = credentials('Jenkins-bootstrap-secret-access-key')
        TF_VAR_project_region     = "us-east-1"
        HOME_DIR                  = "Bootstrap"
    }


    stages {
        stage('Resolve Environments') {
            steps {
                script {
                    def envFiles = findFiles(glob: "${env.HOME_DIR}/envs/*.tfvars")

                    // Build a list of envs to deploy/destroy based on flags
                    def deployTargets  = []
                    def destroyTargets = []

                    envFiles.each { file ->
                        def content   = readFile(file.path)
                        def deployEnv = file.name.replace('.tfvars', '')

                        def forceRedeploy = content =~ /force_redeploy\s*=\s*true/
                        def forceDestroy  = content =~ /force_destroy\s*=\s*true/
                
                        if (forceDestroy) {
                            echo "${deployEnv}: force_destroy = true → queued for destroy"
                            destroyTargets << deployEnv
                        } else if (forceRedeploy) {
                            echo "${deployEnv}: force_redeploy = true → queued for deploy"
                            deployTargets << deployEnv
                        } else {
                            echo "${deployEnv}: no flags set → skipping"
                        }
                    }

                    if (deployTargets.isEmpty() && destroyTargets.isEmpty()) {
                        echo "No environments flagged — nothing to do"
                        currentBuild.result = 'NOT_BUILT'
                        return
                    }

                    // Store as comma-separated strings for downstream stages
                    env.DEPLOY_TARGETS  = deployTargets.join(',')
                    env.DESTROY_TARGETS = destroyTargets.join(',')

                    echo "Deploy targets:  ${env.DEPLOY_TARGETS}"
                    echo "Destroy targets: ${env.DESTROY_TARGETS}"
                }
            }
        }
        stage('Disclaimer') {
            steps {
                echo """
                    ==========================================
                    INFRASTRUCTURE DEPLOYMENT PIPELINE ONLY
                    ==========================================
                    This pipeline manages AWS infrastructure.
                    Do not use for application deployments.

                    WARNING - IAM USERS:
                    Redeploying with a new username WILL DELETE
                    the previous IAM user and replace it with
                    the new one. To keep existing users, include
                    ALL usernames in the input.

                    Updates: We are still working on creating many users at a time
                    ==========================================
                """
            }
        }
        stage('Terraform Destroy'){
            when {
                allOf{
                    changeset "Bootstrap/*"
                    expression { env.DESTROY_TARGETS?.trim() }
                }
            }
            steps{
                script {
                    env.DESTROY_TARGETS.split(',').each { deployEnv ->
                        sh """
                            cd ${env.HOME_DIR}
                            terraform workspace select ${deployEnv}

                            terraform plan \
                                -destroy \
                                -var-file=envs/${deployEnv}.tfvars \
                                -out=destroy.tfplan

                            terraform apply -auto-approve destroy.tfplan
                        """
                    }
                }
            }
        }

        stage('Terraform init'){
            when {
                allOf{
                    changeset "Bootstrap/*"
                    expression { env.DEPLOY_TARGETS?.trim() }
                }
            }
            steps{
                script {
                    env.DEPLOY_TARGETS.split(',').each { deployEnv ->
                        sh """
                            cd ${env.HOME_DIR}
                            echo 'init - current directory is ${env.HOME_DIR}'
                            terraform init
                            
                        """
                    }
                }
            }
        }

        stage('Terraform Plan & Apply'){
            when {
                allOf{
                    changeset "Bootstrap/*"
                    expression { env.DEPLOY_TARGETS?.trim() }
                }
            }
            steps{
                script{
                    env.DEPLOY_TARGETS.split(',').each { deployEnv ->
                        sh """
                            cd ${env.HOME_DIR}
                            terraform workspace select ${deployEnv} || terraform workspace new ${deployEnv}
                            terraform plan    -var-file=envs/${deployEnv}.tfvars --out=tfplan
                            terraform apply tfplan 
                        """
                    }
                }
            }
        }
        stage('Show Outputs') {
            when {
                allOf{
                    changeset "Bootstrap/*"
                    expression { env.DEPLOY_TARGETS?.trim() }
                }
            }
            steps {
                script {
                    def newUsername = sh(
                        script: "cd ${env.HOME_DIR} && terraform output -raw new_username_output",
                        returnStdout: true
                    ).trim()
                    
                    echo "New IAM Username: ${newUsername}"
                    env.NEW_USERNAME = newUsername  // store it for later stages
                }
            }
        }
    }

    post {
        success {
            sh "echo 'Pipeline Successfully Deployed.' "
        }
        unsuccessful {
            sh """
                echo 'Pipeline Failed - Review logs.'
            """
        }
    }
}