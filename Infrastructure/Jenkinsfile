/******************************************************************************************/
// AUDIT TRAIL - version 2.0.0 May 16th 2026
/******************************************************************************************/

pipeline {
    agent any

    parameters {
        booleanParam(
            name: 'DEPLOY_VPN',
            defaultValue: false,
            description: 'Check this only when you want to deploy the VPN'
        )
    }

    environment {
        HOME_DIR              = "Infrastructure"
        AWS_ACCESS_KEY_ID     = credentials('Jenkins-infrastructure-access-key')
        AWS_SECRET_ACCESS_KEY = credentials('Jenkins-infrastructure-secret-access-key')
        NGROK_TOKEN           = credentials('NGROK_TOKEN')
        TF_VAR_workspace      = "${WORKSPACE}"
        TF_VAR_project_region = "us-east-1"
        TF_VAR_enable_vpn     = "${params.DEPLOY_VPN}"
    }

    stages {

        stage('Resolve Environments') {
            steps {
                script {
                    def envFiles = findFiles(glob: "${env.HOME_DIR}/envs/*.tfvars")

                    // Build a list of envs to deploy/destroy based on flags
                    def deployTargets  = []
                    def destroyTargets = []

                    envFiles.each { file ->
                        def content   = readFile(file.path)
                        def deployEnv = file.name.replace('.tfvars', '')

                        def forceRedeploy = content =~ /force_redeploy\s*=\s*true/
                        def forceDestroy  = content =~ /force_destroy\s*=\s*true/

                        if (forceRedeploy) {
                            echo "${deployEnv}: force_redeploy = true → queued for deploy"
                            deployTargets << deployEnv
                        } else if (forceDestroy) {
                            echo "${deployEnv}: force_destroy = true → queued for destroy"
                            destroyTargets << deployEnv
                        } else {
                            echo "${deployEnv}: no flags set → skipping"
                        }
                    }

                    if (deployTargets.isEmpty() && destroyTargets.isEmpty()) {
                        echo "No environments flagged — nothing to do"
                        currentBuild.result = 'NOT_BUILT'
                        return
                    }

                    // Store as comma-separated strings for downstream stages
                    env.DEPLOY_TARGETS  = deployTargets.join(',')
                    env.DESTROY_TARGETS = destroyTargets.join(',')

                    echo "Deploy targets:  ${env.DEPLOY_TARGETS}"
                    echo "Destroy targets: ${env.DESTROY_TARGETS}"
                }
            }
        }

        stage('Terraform Init & Deploy') {
            when {
                expression { env.DEPLOY_TARGETS?.trim() }
            }
            steps {
                script {
                    env.DEPLOY_TARGETS.split(',').each { deployEnv ->

                        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                        echo "Deploying: ${deployEnv}"
                        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                        sh """
                            cd ${env.HOME_DIR}
                            chmod -R +rx *
                            terraform init
                            terraform workspace select ${deployEnv} || terraform workspace new ${deployEnv}
                            terraform plan    -var-file=envs/${deployEnv}.tfvars
                            terraform apply   -var-file=envs/${deployEnv}.tfvars --auto-approve
                        """
                    }
                }
            }
        }

        stage('OVPN File Configuration') {
            when {
                expression { env.DEPLOY_TARGETS?.trim() }
            }
            steps {
                script {
                    env.DEPLOY_TARGETS.split(',').each { deployEnv ->
                        def content    = readFile("${env.HOME_DIR}/envs/${deployEnv}.tfvars")
                        def deployVpn  = content =~ /enable_vpn\s*=\s*true/

                        if (deployVpn) {
                            echo "${deployEnv}: enable_vpn = true → configuring OVPN"

                            sh """
                                cd "${env.HOME_DIR}/Client-VPN-Conf/"

                                ENDPOINT_ID=\$(aws ec2 describe-client-vpn-endpoints \
                                    --region "${env.TF_VAR_project_region}" \
                                    --query 'ClientVpnEndpoints[0].ClientVpnEndpointId' \
                                    --output text)

                                aws ec2 export-client-vpn-client-configuration \
                                    --region "${env.TF_VAR_project_region}" \
                                    --client-vpn-endpoint-id \$ENDPOINT_ID \
                                    --output text > downloaded.ovpn
                            """
                            sh "cd ${env.HOME_DIR}/Client-VPN-Conf/ && ./generate_ovpn.sh andres downloaded.ovpn ${env.WORKSPACE}/${env.HOME_DIR}"
                            sh "aws s3 cp ${env.HOME_DIR}/Client-VPN-Conf/andres.ovpn s3://cloud-cabral-ovpn-files/${deployEnv}/andres.ovpn"
                        } else {
                            echo "${deployEnv}: enable_vpn = false → skipping OVPN"
                        }
                    }
                }
            }
        }

        stage('Terraform Destroy') {
            when {
                expression { env.DESTROY_TARGETS?.trim() }
            }
            steps {
                script {
                    env.DESTROY_TARGETS.split(',').each { deployEnv ->
                        sh """
                            cd ${env.HOME_DIR}
                            terraform workspace select ${deployEnv}

                            terraform plan \
                                -destroy \
                                -var-file=envs/${deployEnv}.tfvars \
                                -out=destroy.tfplan

                            terraform apply -auto-approve destroy.tfplan
                        """
                    }
                }
            }
        }

    }

    post {
        success {
            echo "Pipeline completed successfully — deployed: ${env.DEPLOY_TARGETS} | destroyed: ${env.DESTROY_TARGETS}"
        }
        unsuccessful {
            echo "Pipeline failed — deployed: ${env.DEPLOY_TARGETS} | destroyed: ${env.DESTROY_TARGETS}"
        }
        changed {
            echo "Infrastructure state changed"
        }
    }
}